# miniMDM environment configuration
# Copy this file to .env and adjust values for your environment

# PostgreSQL connection string
DATABASE_URL=postgresql://minimdm:minimdm@localhost:5432/minimdm

# Path to the miniMDM config file (YAML or JSON)
CONFIG_FILE=config/minimdm.yaml

# Application settings
APP_NAME=miniMDM
DEBUG=false

# Server settings
HOST=0.0.0.0
PORT=8000
